# Jump.rs Configuration
# Copy this file to config.toml. Environment variables with the JUMPERS_ prefix
# override file values. Use JUMPERS_CONFIG to point at a custom path.

[server]
# HTTP port to listen on
port = 3000

# Log level: "trace", "debug", "info", "warn", "error"
log_level = "info"

# Log output format: "compact", "json", or "pretty"
log_format = "compact"

[auth]
# Disable authentication entirely (recommended until users are configured).
disabled = true

# User credentials: username:bcrypt_hash,username:bcrypt_hash
# Bcrypt hashes start with "$2" (e.g., "$2b$12$...")
# Docker Compose requires escaping "$" as "$$" (e.g., "$$2b$$12$$...")
# Generate: htpasswd -bnBC 12 "" password | tr -d ':\n'
users = ""

# Session timeout in seconds
session_timeout = 86400

# Allow cookies over insecure HTTP (useful for local development)
allow_insecure_cookies = false

# Explicit origins allowed for auth actions
# Supports single-wildcard patterns like "http://localhost:*"
# NOTE: "*" is rejected when auth is enabled.
# Example: ["http://localhost:5173", "http://localhost:*"]
allow_origins = []

[storage]
# Path to the JSON file storing device data
file_path = "devices.json"

[wol]
# Default UDP port for Wake-on-LAN magic packets (standard is 9)
default_port = 9

[otel]
# OpenTelemetry OTLP endpoint (requires "otlp" feature)
# If not set, OTEL tracing is disabled.
endpoint = "http://localhost:4317"

# Service name for traces
service_name = "jump_rs"
